        <record id="hr_rule_mr_net" model="hr.salary.rule">
            <field name="name">Net à Payer</field>
            <field name="code">NET</field>
            <field name="sequence">900</field>
            <field name="category_id" ref="hr_salary_rule_category_net_mr"/>
            <field name="struct_id" ref="structure_mr_employee"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = sum(l.total for l in payslip.line_ids
    if l.category_id.code in ('GROSS_MR','DED_MR','ALW_MR','OT_MR','BASIC_MR'))
            </field>
            <field name="appears_on_payslip">True</field>
        </record>

    </data>
</odoo>
