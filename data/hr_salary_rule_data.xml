<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="hr_rule_mr_basic" model="hr.salary.rule">
            <field name="name">Salaire de Base</field>
            <field name="code">BASIC</field>
            <field name="sequence">10</field>
            <field name="category_id" ref="hr_salary_rule_category_basic_mr"/>
            <field name="struct_id" ref="structure_mr_employee"/>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = contract.wage</field>
            <field name="appears_on_payslip">True</field>
        </record>

        <record id="hr_rule_mr_overtime_day" model="hr.salary.rule">
            <field name="name">Heures Supp. Jour (x1,15)</field>
            <field name="code">OT_DAY</field>
            <field name="sequence">20</field>
            <field name="category_id" ref="hr_salary_rule_category_overtime_mr"/>
            <field name="struct_id" ref="structure_mr_employee"/>
            <field name="condition_select">python</field>
            <field name="condition_python">result = contract.l10n_mr_overtime_hours > 0</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = (contract.wage / 173.33) * contract.l10n_mr_overtime_hours * 1.15
            </field>
            <field name="appears_on_payslip">True</field>
        </record>

        <record id="hr_rule_mr_overtime_night" model="hr.salary.rule">
            <field name="name">Heures Supp. Nuit (x1,40)</field>
